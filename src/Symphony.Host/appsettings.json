{
  "Symphony": {
    "Polling": {
      "IntervalMs": 600000
    },
    "Agent": {
      "MaxConcurrentAgents": 5
    }
  },
  "Orchestration": {
    "InstanceId": "",
    "LeaseName": "poll-dispatch",
    "LeaseTtlSeconds": 900
  },
  "Persistence": {
    "ConnectionString": "Data Source=./data/symphony.db;Cache=Shared;Mode=ReadWriteCreate"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
