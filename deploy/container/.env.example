GITHUB_TOKEN=ghp_replace_me
SYMPHONY_IMAGE=symphony:dev
SYMPHONY_HTTP_PORT=8080
SYMPHONY_INSTANCE_ID=orchestrator-1
CODEX_NPM_VERSION=0.114.0

# Absolute or compose-file-relative path to the externally managed workflow file.
SYMPHONY_WORKFLOW_HOST_PATH=C:/symphony/config/WORKFLOW.md

# Path to a Codex CLI home directory that already contains login/config state.
CODEX_HOME_HOST_PATH=C:/symphony/codex-home
